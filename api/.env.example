ENV=local
DB_HOST=your-mysql-host.example.com
DB_PORT=3306
DB_USER=rsvp_user
DB_PASSWORD=your_password
DB_NAME=rsvp
FRONTEND_ORIGIN=http://localhost:5173
# Optional: comma-separated extra origins (custom domains, preview URLs)
# FRONTEND_ORIGINS=https://rsvp.example.com
TEST_INVITE_ID=1234567890123456789

# Admin login (required for /admin/* routes)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Optional: separate secret for signing session tokens (defaults to ADMIN_PASSWORD)
ADMIN_TOKEN_SECRET=
