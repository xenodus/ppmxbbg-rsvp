# Copy to Makefile.include and fill in your values.
# Makefile.include is gitignored.

AWS_ACCOUNT_ID=123456789012
AWS_REGION=ap-southeast-1

ECR_REPO_NAME=ppmxbbg-rsvp-api
LAMBDA_FUNCTION=ppmxbbg-rsvp-api

S3_BUCKET=ppmxbbg-rsvp-frontend
CLOUDFRONT_DISTRIBUTION_ID=

# API Gateway → Stages → Invoke URL (include stage path, no trailing slash)
# Find in AWS Console: API Gateway → your API → Stages
VITE_API_BASE_URL=https://YOUR_API_ID.execute-api.ap-southeast-1.amazonaws.com/prod
